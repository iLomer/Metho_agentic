{
  "name": "meto-cockpit",
  "version": "0.1.0",
  "description": "Meto Cockpit -- multi-project orchestrator for Claude Code sessions",
  "private": true,
  "type": "module",
  "author": "iLomer",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:vite": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint": "^9.17.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.0"
  },
  "build": {
    "electronVersion": "33.4.11",
    "appId": "com.meto.cockpit",
    "productName": "Meto Cockpit",
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ]
  }
}
