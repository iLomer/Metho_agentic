{
  "name": "meto-cli",
  "version": "0.1.2",
  "description": "Scaffold structured software projects with built-in methodology",
  "type": "module",
  "bin": {
    "meto-cli": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "scaffold",
    "cli",
    "methodology",
    "agile",
    "project-generator"
  ],
  "author": "iLomer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iLomer/Metho_agentic.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
