#!/bin/sh
# Mock Claude Code binary that succeeds on --version but fails on -p.
# Used by tests/cli/ai-integration.test.ts for fallback testing.

# Handle --version check (preflight) -- succeed so AI path is triggered
if [ "$1" = "--version" ]; then
  echo "mock-claude-fail 1.0.0"
  exit 0
fi

# Handle -p flag (AI generation) -- fail with exit code 1
if [ "$1" = "-p" ]; then
  echo "Error: Claude Code process crashed" >&2
  exit 1
fi

echo "Unknown arguments: $@" >&2
exit 1
